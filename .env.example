# Copy to .env (gitignored) and fill in real values.
#
# Non-secret defaults (DATABASE_URL, PORT, OMNIBUS_PUBLIC_ORIGIN,
# PLAYWRIGHT_BROWSERS_PATH, ANDROID_HOME, …) continue to live in the
# flake.nix shellHook. This file is only for values the shellHook
# shouldn't carry — typically passwords, tokens, or per-developer
# overrides. The shellHook sources .env *after* its own exports, so any
# entry here overrides the matching shellHook default.

# Seeds an admin user on server boot if not already present. Strictly a
# dev convenience — production must NOT set this. Format: username:password.
# Password must be >= 10 chars and not in the common-password list
# (db/src/auth.rs::COMMON_PASSWORDS).
#
# The dev-up script and the ui-validate skill assume this exact value;
# change it only if you understand both will follow you.
OMNIBUS_DEV_SEED_USER=admin:omnibus-dev
